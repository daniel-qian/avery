# ── Avery eval-harness · real-run config (MiniMax, OpenAI-compatible) ─────────────────
# This is the TEMPLATE (committed, no secrets). The real file is `.env` (gitignored).
# A blank `.env` has already been created for you — just open it and paste your key.
#
#   1) open  eval-harness/.env
#   2) paste your MiniMax key right after  MINIMAX_API_KEY=   (no quotes, no spaces)
#   3) save. Done. Any `--real` run picks it up automatically.
#
# Get a key:  https://platform.minimaxi.com
# API docs:   https://platform.minimaxi.com/docs/api-reference/text-openai-api

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# Judges must be NON-Claude (self-preference bias) — MiniMax qualifies. For a publishable run,
# add a 2nd real family (comma-separated), e.g.  minimax:MiniMax-M3,openai:gpt-4o
JUDGE_FAMILIES=minimax:MiniMax-M3
